# Cada deploy (QA/PROD) es UN país fijo: se configura via env en el pipeline de CI/CD,
# no se resuelve en runtime. Ver src/config/environment.ts y src/proxy.ts.

# País del deploy. Valores válidos: cl | co | pe (ver COUNTRIES en src/config/types.ts).
# Si falta o es inválida, hoy cae silenciosamente a "cl" (src/config/environment.ts:3-6).
NEXT_PUBLIC_COUNTRY=cl

# Alias de COUNTRY leído solo en servidor (server components/actions), con prioridad
# sobre NEXT_PUBLIC_COUNTRY en src/config/environment.ts:4. Normalmente basta con
# NEXT_PUBLIC_COUNTRY; se deja documentado porque el código lo lee explícitamente.
# COUNTRY=cl

# Ambiente. Valores válidos: local | qa | prod (cualquier otro valor cae a "local").
# En "local" el proxy (src/proxy.ts:31) no aplica el guard de pasos del flujo.
NEXT_PUBLIC_ENVIRONMENT=local
